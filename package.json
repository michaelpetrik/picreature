{
  "name": "picreature",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "changelog": "node scripts/generate-changelog.mjs",
    "changelog:check": "node scripts/generate-changelog.mjs --check",
    "guard:bootstrap": "bash scripts/ci/install_dev_tools.sh",
    "guard:hooks:install": "bash scripts/ci/install_hooks.sh",
    "guard:gitnexus:bootstrap": "bash scripts/ci/bootstrap_gitnexus.sh",
    "guard:gitnexus:status": "bash scripts/ci/check_gitnexus.sh",
    "guard:pre-commit": "bash scripts/ci/run_pre_commit_checks.sh",
    "guard:quality": "bash scripts/ci/run_quality_gates.sh",
    "guard:secrets": "bash scripts/ci/check_no_secrets.sh",
    "guard:docker": "bash scripts/ci/check_docker_runtime.sh",
    "guard:security": "bash scripts/ci/run_security_review.sh"
  },
  "dependencies": {
    "@google/genai": "^1.47.0",
    "next": "^16.2.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "gitnexus": "^1.5.3",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
